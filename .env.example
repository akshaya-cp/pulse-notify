# Server
APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Logging: debug | info | warn | error
LOG_LEVEL=info

# PostgreSQL (matches docker-compose.yml)
# Use 5432 with Docker Compose, or 5433 if using Homebrew Postgres on a busy machine
DATABASE_URL=postgres://pulse:pulse@127.0.0.1:5433/pulse_notify?sslmode=disable

# JWT — use a long random secret in production (min 32 chars)
JWT_SECRET=dev-only-change-this-secret-before-production-use
JWT_ACCESS_TTL=15m
