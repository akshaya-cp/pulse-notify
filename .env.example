# Server
APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Logging: debug | info | warn | error
LOG_LEVEL=info

# PostgreSQL (matches docker-compose.yml port mapping)
DATABASE_URL=postgres://pulse:pulse@127.0.0.1:5432/pulse_notify?sslmode=disable

# Redis (matches docker-compose.yml port mapping)
REDIS_URL=redis://127.0.0.1:6379/0

# Kafka
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC=notifications
KAFKA_GROUP_ID=pulse-notify-workers

# JWT — use a long random secret in production (min 32 chars)
JWT_SECRET=dev-only-change-this-secret-before-production-use
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Notification worker pool
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3

# Rate limiting (fixed window, per client IP). Set REQUESTS=0 to disable.
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
